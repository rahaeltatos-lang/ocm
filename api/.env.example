# Database
DATABASE_URL=postgresql://openclawmatrix:password@localhost:5432/openclawmatrix
DB_HOST=localhost
DB_PORT=5432
DB_NAME=openclawmatrix
DB_USER=openclawmatrix
DB_PASSWORD=password

# API
API_PORT=4001
NODE_ENV=development
API_URL=http://localhost:4001

# Frontend
FRONTEND_URL=http://localhost:3001

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRY=7d

# Payments (DodoPayments - placeholder)
DODOPAYMENTS_API_KEY=placeholder_key
DODOPAYMENTS_SECRET=placeholder_secret

# Email (optional - for email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=password
SMTP_FROM=noreply@openclawmatrix.com

# OpenClawMatrix Integration
OCM_API_URL=http://localhost:4000
OCM_SERVICE_ACCOUNT_TOKEN=your_service_account_token_here
